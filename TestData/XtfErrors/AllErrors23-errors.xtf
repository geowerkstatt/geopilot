			<!-- ===== constraints ===== -->
			<!-- Mandatory Constraint ...MandatoryConstraintClass.CONSTRAINT is not true (firstFlag != secondFlag) -->
			<AllErrors23.MainTopic.MandatoryConstraintClass TID="mandatoryConstraintViolated"><firstFlag>true</firstFlag><secondFlag>false</secondFlag></AllErrors23.MainTopic.MandatoryConstraintClass>
			<!-- Plausibility Constraint ...PlausibilityConstraintClass.CONSTRAINT is not true (0% satisfy firstNumber>=secondNumber) -->
			<AllErrors23.MainTopic.PlausibilityConstraintClass TID="plausibilityConstraintViolated"><firstNumber>1</firstNumber><secondNumber>9</secondNumber></AllErrors23.MainTopic.PlausibilityConstraintClass>
			<!-- Set Constraint ...SetConstraintClass.CONSTRAINT is not true (count of categoryValue=a is 2, expected 5) -->
			<AllErrors23.MainTopic.SetConstraintClass TID="setConstraintObject1"><categoryValue>a</categoryValue></AllErrors23.MainTopic.SetConstraintClass>
			<AllErrors23.MainTopic.SetConstraintClass TID="setConstraintObject2"><categoryValue>a</categoryValue></AllErrors23.MainTopic.SetConstraintClass>
			<!-- Unique constraint ...UniqueConstraintClass.CONSTRAINT is violated -->
			<AllErrors23.MainTopic.UniqueConstraintClass TID="uniqueConstraintObject1"><keyText>same</keyText><keyNumber>7</keyNumber></AllErrors23.MainTopic.UniqueConstraintClass>
			<AllErrors23.MainTopic.UniqueConstraintClass TID="uniqueConstraintObject2"><keyText>same</keyText><keyNumber>7</keyNumber></AllErrors23.MainTopic.UniqueConstraintClass>
			<!-- Existence constraint ... is violated (value "missing" not present in any ConditionClass) -->
			<AllErrors23.MainTopic.ExistenceConstraintClass TID="existenceConstraintViolated"><referencedText>missing</referencedText></AllErrors23.MainTopic.ExistenceConstraintClass>

			<!-- ===== reference / association (LinkAssociation) ===== -->
			<!-- valid baseline pair so role target (1..1) of validSource is satisfied -->
			<AllErrors23.MainTopic.LinkSourceClass TID="validSource"><label>source</label></AllErrors23.MainTopic.LinkSourceClass>
			<AllErrors23.MainTopic.LinkTargetClass TID="validTarget"><label>target</label></AllErrors23.MainTopic.LinkTargetClass>
			<AllErrors23.MainTopic.LinkAssociation><source REF="validSource"></source><target REF="validTarget"></target></AllErrors23.MainTopic.LinkAssociation>
			<!-- role cardinality: LinkSourceClass with no association -> should associate to 1 target object (instead of 0) -->
			<AllErrors23.MainTopic.LinkSourceClass TID="sourceWithoutLink"><label>lonely</label></AllErrors23.MainTopic.LinkSourceClass>
			<!-- No object found with OID missingTarget (role source points at a missing object) -->
			<AllErrors23.MainTopic.LinkAssociation><source REF="missingTarget"></source><target REF="validTarget"></target></AllErrors23.MainTopic.LinkAssociation>
			<!-- wrong class of target object (role source points at a LinkTargetClass instead of LinkSourceClass) -->
			<AllErrors23.MainTopic.LinkAssociation><source REF="validTarget"></source><target REF="validTarget"></target></AllErrors23.MainTopic.LinkAssociation>

			<!-- unknown class <AllErrors23.MainTopic.UndefinedClass> -->
			<AllErrors23.MainTopic.UndefinedClass TID="objectOfUnknownClass"><label>y</label></AllErrors23.MainTopic.UndefinedClass>

