			<MODEL NAME="AllErrors23" VERSION="2026-06-10" URI="mailto:joel.waelti@geowerkstatt.ch"></MODEL>
		</MODELS>
	</HEADERSECTION>
	<DATASECTION>
		<AllErrors23.MainTopic BID="mainBasket">

			<!-- ===== type / value errors (ValueTypeClass) ===== -->
			<!-- value <abc> is not a number in attribute numberValue -->
			<AllErrors23.MainTopic.ValueTypeClass TID="valueNotANumber"><numberValue>abc</numberValue></AllErrors23.MainTopic.ValueTypeClass>
			<!-- value 999 is out of range in attribute numberValue -->
			<AllErrors23.MainTopic.ValueTypeClass TID="numberOutOfRange"><numberValue>999.00</numberValue></AllErrors23.MainTopic.ValueTypeClass>
			<!-- Attribute limitedText is length restricted to 5 -->
			<AllErrors23.MainTopic.ValueTypeClass TID="textTooLong"><limitedText>toolong</limitedText></AllErrors23.MainTopic.ValueTypeClass>
			<!-- value <maybe> is not a BOOLEAN in attribute booleanFlag -->
			<AllErrors23.MainTopic.ValueTypeClass TID="valueNotABoolean"><booleanFlag>maybe</booleanFlag></AllErrors23.MainTopic.ValueTypeClass>
			<!-- value yellow is not a member of the enumeration in attribute colourValue -->
			<AllErrors23.MainTopic.ValueTypeClass TID="valueNotInEnumeration"><colourValue>yellow</colourValue></AllErrors23.MainTopic.ValueTypeClass>
			<!-- invalid format of date value <15.06.2005> in attribute dateValue -->
			<AllErrors23.MainTopic.ValueTypeClass TID="invalidDateFormat"><dateValue>15.06.2005</dateValue></AllErrors23.MainTopic.ValueTypeClass>
			<!-- date value <1999-06-15> is not in range in attribute dateValue -->
			<AllErrors23.MainTopic.ValueTypeClass TID="dateOutOfRange"><dateValue>1999-06-15</dateValue></AllErrors23.MainTopic.ValueTypeClass>
			<!-- invalid format of time value <99:99:99.999> in attribute timeValue -->
			<AllErrors23.MainTopic.ValueTypeClass TID="invalidTimeFormat"><timeValue>99:99:99.999</timeValue></AllErrors23.MainTopic.ValueTypeClass>
			<!-- datetime value <1999-06-15T12:00:00.000> is not in range in attribute dateTimeValue -->
			<AllErrors23.MainTopic.ValueTypeClass TID="dateTimeOutOfRange"><dateTimeValue>1999-06-15T12:00:00.000</dateTimeValue></AllErrors23.MainTopic.ValueTypeClass>
			<!-- invalid format of INTERLIS.NAME value <1bad> in attribute interlisName -->
			<AllErrors23.MainTopic.ValueTypeClass TID="invalidInterlisName"><interlisName>1bad</interlisName></AllErrors23.MainTopic.ValueTypeClass>
			<!-- value <TRANSFER> is a keyword in attribute interlisName -->
			<AllErrors23.MainTopic.ValueTypeClass TID="nameIsKeyword"><interlisName>TRANSFER</interlisName></AllErrors23.MainTopic.ValueTypeClass>
			<!-- invalid format of INTERLIS.URI value <ht tp://b ad> in attribute interlisUri -->
			<AllErrors23.MainTopic.ValueTypeClass TID="invalidInterlisUri"><interlisUri>ht tp://b ad</interlisUri></AllErrors23.MainTopic.ValueTypeClass>
			<!-- value <not-a-uuid> is not a valid UUID in attribute uuidValue -->
			<AllErrors23.MainTopic.ValueTypeClass TID="invalidUuid"><uuidValue>not-a-uuid</uuidValue></AllErrors23.MainTopic.ValueTypeClass>
			<!-- unknown property <ghostAttribute> -->
			<AllErrors23.MainTopic.ValueTypeClass TID="unknownProperty"><ghostAttribute>x</ghostAttribute></AllErrors23.MainTopic.ValueTypeClass>
			<!-- OID duplicateOid already exists (two objects share the same TID) -->
			<AllErrors23.MainTopic.ValueTypeClass TID="duplicateOid"><numberValue>1.00</numberValue></AllErrors23.MainTopic.ValueTypeClass>
			<AllErrors23.MainTopic.ValueTypeClass TID="duplicateOid"><numberValue>2.00</numberValue></AllErrors23.MainTopic.ValueTypeClass>

			<!-- ===== control characters (NormalizedTextClass) ===== -->
			<!-- Attribute normalizedText must not contain control characters (embedded TAB) -->
			<AllErrors23.MainTopic.NormalizedTextClass TID="textWithControlChar"><normalizedText>tab&#9;here</normalizedText></AllErrors23.MainTopic.NormalizedTextClass>

			<!-- ===== multiplicity (MultiplicityClass) ===== -->
			<!-- Attribute mandatoryText requires a value (mandatory attribute omitted) -->
			<AllErrors23.MainTopic.MultiplicityClass TID="missingMandatoryValue">
				<itemBag><AllErrors23.MainTopic.ItemStructure><itemText>x</itemText></AllErrors23.MainTopic.ItemStructure></itemBag>
			</AllErrors23.MainTopic.MultiplicityClass>
			<!-- Attribute itemBag has wrong number of values (3 > max 2) -->
			<AllErrors23.MainTopic.MultiplicityClass TID="tooManyBagValues">
				<mandatoryText>present</mandatoryText>
				<itemBag>
					<AllErrors23.MainTopic.ItemStructure><itemText>a</itemText></AllErrors23.MainTopic.ItemStructure>
					<AllErrors23.MainTopic.ItemStructure><itemText>b</itemText></AllErrors23.MainTopic.ItemStructure>
					<AllErrors23.MainTopic.ItemStructure><itemText>c</itemText></AllErrors23.MainTopic.ItemStructure>
				</itemBag>
			</AllErrors23.MainTopic.MultiplicityClass>

			<!-- ===== geometry structure (GeometryClass) ===== -->
			<!-- Wrong COORD structure, C2 expected -->
			<AllErrors23.MainTopic.GeometryClass TID="coordMissingC2"><pointCoord><COORD><C1>2645001.000</C1></COORD></pointCoord></AllErrors23.MainTopic.GeometryClass>
			<!-- Wrong COORD structure, C3 not expected (pointCoord is 2D) -->
			<AllErrors23.MainTopic.GeometryClass TID="coordUnexpectedC3"><pointCoord><COORD><C1>2645001.000</C1><C2>1245002.000</C2><C3>3.000</C3></COORD></pointCoord></AllErrors23.MainTopic.GeometryClass>
			<!-- invalid number of segments in POLYLINE (only one vertex) -->
			<AllErrors23.MainTopic.GeometryClass TID="polylineTooFewSegments"><straightPolyline><POLYLINE><COORD><C1>2645000.000</C1><C2>1245000.000</C2></COORD></POLYLINE></straightPolyline></AllErrors23.MainTopic.GeometryClass>
			<!-- Wrong ARC structure (ARC without A1/A2) -->
			<AllErrors23.MainTopic.GeometryClass TID="invalidArcStructure"><arcPolyline><POLYLINE><COORD><C1>2645000.000</C1><C2>1245000.000</C2></COORD><ARC><C1>2645010.000</C1><C2>1245000.000</C2></ARC></POLYLINE></arcPolyline></AllErrors23.MainTopic.GeometryClass>
			<!-- failed to validate polygon / missing outerboundary (open ring) -->
			<AllErrors23.MainTopic.GeometryClass TID="openSurfaceBoundary">
				<surface><SURFACE><BOUNDARY><POLYLINE>
