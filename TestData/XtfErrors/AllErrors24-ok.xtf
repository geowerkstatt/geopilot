			<ExistenceConstraintClass ili:tid="existingReference"><referencedText>lookup</referencedText></ExistenceConstraintClass>

			<!-- the target role has max cardinality 1, so the link is embedded in LinkSourceClass -->
			<LinkSourceClass ili:tid="validSource"><label>source</label><target ili:ref="validTarget"/></LinkSourceClass>
			<LinkTargetClass ili:tid="validTarget"><label>target</label></LinkTargetClass>

