<?xml version="1.0" encoding="UTF-8"?>
<!-- INTERLIS 2.4 sample data for the public federal model "DMAV_Bodenbedeckung_V1_1"
     (https://models.geo.admin.ch/V_D/, resolved automatically from the model
     repositories). Old state for the xtf_comparison pipeline (XTF-Diff-Tool): zip this
     file together with test_dmav_2.xtf and upload the archive. The XTF-Diff-Tool only
     compares objects whose class declares a stable OID in the INTERLIS model; the
     Bodenbedeckung topic declares OID AS INTERLIS.UUIDOID, so basket and object ids
     below are UUIDs and stay identical across both files. Compared to this file,
     test_dmav_2.xtf moves point P1 slightly and adds a new point P3. -->
