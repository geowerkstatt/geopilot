<?xml version="1.0" encoding="UTF-8"?>
<!-- INTERLIS 2.4 sample data for the public federal model "Grundwasservorkommen_V2_0"
     (https://models.geo.admin.ch/BAFU/, version 2024-10-15) containing a DELIBERATE
     GEOMETRY ERROR. The Geringdurchlaessige_Deckschicht.Geometrie boundary below is a
     self-intersecting "bowtie": edge 1 (2640300,1172560)->(2640340,1172590) crosses
     edge 3 (2640340,1172560)->(2640300,1172590) at LV95 position (2640320, 1172575).
     A surface boundary must be a simple (non-self-intersecting) ring, so ilivalidator
     reports an intersection error AT THAT POSITION (the "red" path). All coordinates are
     valid LV95 values; the only error is the self-intersection. -->
<ili:transfer xmlns:ili="http://www.interlis.ch/xtf/2.4/INTERLIS"
  xmlns:geom="http://www.interlis.ch/geometry/1.0"
  xmlns="http://www.interlis.ch/xtf/2.4/Grundwasservorkommen_V2_0">
