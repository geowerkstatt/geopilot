      <ili:model>Grundwasservorkommen_V2_0</ili:model>
    </ili:models>
    <ili:sender>geopilot</ili:sender>
  </ili:headersection>
  <ili:datasection>
    <Grundwasservorkommen ili:bid="bGwv1">
      <!-- ERROR: self-intersecting boundary (bowtie); edges cross at (2640320, 1172575). -->
      <Geringdurchlaessige_Deckschicht ili:tid="t1">
        <Geometrie>
          <geom:surface>
            <geom:exterior>
              <geom:polyline>
                <geom:coord><geom:c1>2640300.000</geom:c1><geom:c2>1172560.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640340.000</geom:c1><geom:c2>1172590.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640340.000</geom:c1><geom:c2>1172560.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640300.000</geom:c1><geom:c2>1172590.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640300.000</geom:c1><geom:c2>1172560.000</geom:c2></geom:coord>
              </geom:polyline>
            </geom:exterior>
          </geom:surface>
        </Geometrie>
      </Geringdurchlaessige_Deckschicht>
    </Grundwasservorkommen>
  </ili:datasection>
</ili:transfer>
