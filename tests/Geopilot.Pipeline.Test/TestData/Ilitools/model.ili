INTERLIS 2.4;

MODEL SimpleModel
  AT "mailto:info@geowerkstatt.ch"
  VERSION "2026-07-23" =

  DOMAIN
    !!@CRS=EPSG:2056
    Coord2 = COORD
      2460000.000 .. 2870000.000 [INTERLIS.m],
      1045000.000 .. 1310000.000 [INTERLIS.m],
      ROTATION 2 -> 1;

  TOPIC Testdata  =
    OID AS INTERLIS.UUIDOID;

    CLASS ClassA =
      Name: MANDATORY TEXT*8;
    END ClassA;

    CLASS Point =
      Geometry: MANDATORY Coord2;
    END Point;

  END Testdata;

END SimpleModel.
