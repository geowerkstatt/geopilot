<?xml version="1.0" encoding="UTF-8"?>
<!-- INTERLIS 2.4 sample data for the public federal model "DMAV_Bodenbedeckung_V1_1".
     New state for the xtf_comparison pipeline (XTF-Diff-Tool): zip this file together
     with test_dmav_1.xtf and upload the archive. Same basket and object UUIDs as
     test_dmav_1.xtf so the diff tool matches the objects. Differences to the old
     state: point P1 moved by 0.55 m east / 0.30 m north (geometry "changed"), point
     P3 is new (object "added"), the straight east edge of the L-shaped Bodenbedeckung
     surface is replaced by an arc bulge (geom:arc; geometry "changed" - also exercises
     the arc linearization of the map visualization), BBNachfuehrung N1 gained its
     optional Perimeter surface (geometry "added") and N2 lost it (geometry "deleted").
     P2 is unchanged. -->
<ili:transfer xmlns:ili="http://www.interlis.ch/xtf/2.4/INTERLIS"
  xmlns:geom="http://www.interlis.ch/geometry/1.0"
  xmlns="http://www.interlis.ch/xtf/2.4/DMAV_Bodenbedeckung_V1_1">
  <ili:headersection>
    <ili:models>
      <ili:model>DMAV_Bodenbedeckung_V1_1</ili:model>
    </ili:models>
    <ili:sender>geopilot</ili:sender>
  </ili:headersection>
  <ili:datasection>
    <Bodenbedeckung ili:bid="0bf0a9d9-4d23-4d65-9d27-1a5e3c6f8b2a">
      <Messpunkt ili:tid="9c5d9a4e-7e2b-4f4e-8a1d-3b6c9d2e5f70">
        <Nummer>P1</Nummer>
        <Geometrie>
          <geom:coord><geom:c1>2640300.550</geom:c1><geom:c2>1172560.300</geom:c2></geom:coord>
        </Geometrie>
        <Lagegenauigkeit>0.035</Lagegenauigkeit>
        <IstLagezuverlaessig>true</IstLagezuverlaessig>
        <IstExaktDefiniert>true</IstExaktDefiniert>
      </Messpunkt>
      <Messpunkt ili:tid="5e8f3a21-9b4c-4d6e-8f70-1a2b3c4d5e6f">
        <Nummer>P2</Nummer>
        <Geometrie>
          <geom:coord><geom:c1>2640340.000</geom:c1><geom:c2>1172590.000</geom:c2></geom:coord>
        </Geometrie>
        <Lagegenauigkeit>0.035</Lagegenauigkeit>
        <IstLagezuverlaessig>true</IstLagezuverlaessig>
        <IstExaktDefiniert>true</IstExaktDefiniert>
      </Messpunkt>
      <Messpunkt ili:tid="2a7b4c8d-1e3f-4a5b-9c6d-7e8f90a1b2c3">
        <Nummer>P3</Nummer>
        <Geometrie>
          <geom:coord><geom:c1>2640320.000</geom:c1><geom:c2>1172575.000</geom:c2></geom:coord>
        </Geometrie>
        <Lagegenauigkeit>0.035</Lagegenauigkeit>
        <IstLagezuverlaessig>true</IstLagezuverlaessig>
        <IstExaktDefiniert>true</IstExaktDefiniert>
      </Messpunkt>
      <!-- The class "Bodenbedeckung" collides with its topic name, so its XML element
           name is the qualified "Bodenbedeckung.Bodenbedeckung" (see ili2c
           XSD24Generator.createDef2NameMapping). -->
      <Bodenbedeckung.Bodenbedeckung ili:tid="6f1e9b3c-8d2a-4e7f-b5c0-9a8d7e6f5a4b">
        <!-- Same L-shaped footprint as the old state, but the straight east edge is
             replaced by an arc (geom:arc: a1/a2 = intermediate point on the arc,
             c1/c2 = arc end point, start = previous coord) bulging 6 m east. -->
        <Geometrie>
          <geom:surface>
            <geom:exterior>
              <geom:polyline>
                <geom:coord><geom:c1>2640300.000</geom:c1><geom:c2>1172560.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640340.000</geom:c1><geom:c2>1172560.000</geom:c2></geom:coord>
                <geom:arc><geom:c1>2640340.000</geom:c1><geom:c2>1172576.000</geom:c2><geom:a1>2640346.000</geom:a1><geom:a2>1172568.000</geom:a2></geom:arc>
                <geom:coord><geom:c1>2640318.000</geom:c1><geom:c2>1172576.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640318.000</geom:c1><geom:c2>1172588.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640300.000</geom:c1><geom:c2>1172588.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640300.000</geom:c1><geom:c2>1172560.000</geom:c2></geom:coord>
              </geom:polyline>
            </geom:exterior>
          </geom:surface>
        </Geometrie>
        <Qualitaetsstandard>AV93</Qualitaetsstandard>
        <Fiktiv>true</Fiktiv>
        <Objektstatus>real</Objektstatus>
      </Bodenbedeckung.Bodenbedeckung>
      <BBNachfuehrung ili:tid="8b2d5e1f-3c4a-4b6d-9e0f-1a2b3c4d5e6a">
        <NBIdent>CH040800</NBIdent>
        <Identifikator>NF-2026-001</Identifikator>
        <Beschreibung>Nachfuehrung N1 - Perimeter kommt im neuen Stand dazu</Beschreibung>
        <Perimeter>
          <geom:surface>
            <geom:exterior>
              <geom:polyline>
                <geom:coord><geom:c1>2640360.000</geom:c1><geom:c2>1172562.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640378.000</geom:c1><geom:c2>1172558.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640384.000</geom:c1><geom:c2>1172570.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640372.000</geom:c1><geom:c2>1172580.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640358.000</geom:c1><geom:c2>1172574.000</geom:c2></geom:coord>
                <geom:coord><geom:c1>2640360.000</geom:c1><geom:c2>1172562.000</geom:c2></geom:coord>
              </geom:polyline>
            </geom:exterior>
          </geom:surface>
        </Perimeter>
        <GueltigerEintrag>2026-01-15T08:30:00.000</GueltigerEintrag>
      </BBNachfuehrung>
      <BBNachfuehrung ili:tid="4c9e2f7a-6b1d-4e8c-a3f5-0b9c8d7e6f5d">
        <NBIdent>CH040800</NBIdent>
        <Identifikator>NF-2026-002</Identifikator>
        <Beschreibung>Nachfuehrung N2 - Perimeter entfaellt im neuen Stand</Beschreibung>
        <GueltigerEintrag>2026-01-15T08:30:00.000</GueltigerEintrag>
      </BBNachfuehrung>
    </Bodenbedeckung>
  </ili:datasection>
</ili:transfer>
